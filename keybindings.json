// Place your key bindings in this file to override the defaultsauto[]
[
    // Toggle between terminal and editor focus
    {
        "key": "[Backquote]",
        "command": "workbench.action.terminal.focus"
    },
    {
        "key": "[Backquote]",
        "command": "workbench.action.focusActiveEditorGroup",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+[Quote]",
        "command": "workbench.action.terminal.openNativeConsole",
        "when": "!terminalFocus"
    },
    {
        "key": "ctrl+shift+c",
        "command": "-workbench.action.terminal.openNativeConsole",
        "when": "!terminalFocus"
    },
    {
        "key": "[Backquote]",
        "command": "latex-workshop.synctex",
        "when": "editorTextFocus && !config.latex-workshop.bind.altKeymap.enabled && editorLangId == 'latex'"
    },
    {
        "key": "ctrl+alt+j",
        "command": "-latex-workshop.synctex",
        "when": "editorTextFocus && !config.latex-workshop.bind.altKeymap.enabled && editorLangId == 'latex'"
    },
    {
        "key": "alt+b",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\textbf{${TM_SELECTED_TEXT}}$0"
        }
    },
    {
        "key": "alt+p",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\pause$0"
        }
    },
    {
        "key": "alt+x",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\begin{exo}\n\t$0\n\\begin{exo}"
        }
    },
    {
        "key": "alt+u",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\underline{${TM_SELECTED_TEXT}}$0"
        }
    },
    {
        "key": "shift+enter",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\\\\\\\\n"
        }
    },
    {
        "key": "ctrl+enter",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\pause\n\\medskip\n\n"
        }
    },
    {
        "key": "alt+E",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\begin{alertblock}{Exercice}\n\t$1\n\\end{alertblock}$0"
        }
    },
    {
        "key": "ctrl+D",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\begin{exampleblock}{Définition}\n\t$1\n\\end{exampleblock}$0"
        }
    },
    {
        "key": "ctrl+T",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\begin{alertblock}{Théorème}\n\t$1\n\\end{alertblock}$0"
        }
    },
    {
        "key": "ctrl+P",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\begin{block}{Problème}\n\t$1\n\\end{block}$0"
        }
    },
    {
        "key": "alt+e",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == markdown",
        "args": {
            "snippet": "**Exercice** : "
        }
    },
    {
        "key": "alt+v",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\verb|${TM_SELECTED_TEXT}|$0"
        }
    },
    {
        "key": "alt+v",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == markdown",
        "args": {
            "snippet": "`${TM_SELECTED_TEXT}`"
        }
    },
    {
        "key": "alt+f",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\begin{frame}[fragile]{\\secname}\n\t$2\n\\end{frame}\n$0"
        }
    },
    {
        "key": "alt+m",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\begin{center}\r\n    \\begin{minipage}{0.6\\textwidth}\r\n    \\begin{minted}[frame=single,framesep=10pt]{ocaml}\r\n$1    \r\n    \\end{minted}\r\n    \\end{minipage}\r\n\\end{center}\r\n$0"
        }
    },
    {
        "key": "alt+i",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == markdown",
        "args": {
            "snippet": "<center><img src=img/$1 width=300></center>"
        }
    },
    {
        "key": "alt+m",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == markdown",
        "args": {
            "snippet": "<mark>${TM_SELECTED_TEXT}$1</mark>"
        }
    },
    {
        "key": "alt+s",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\section{${TM_SELECTED_TEXT}$1}$0"
        }
    },
    {
        "key": "alt+c",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == markdown",
        "args": {
            "snippet": "<center>$1</center>"
        }
    },
    {
        "key": "ctrl+q",
        "command": "-workbench.action.quit"
    },
    {
        "key": "ctrl+b",
        "command": "-markdown.extension.editing.toggleBold",
        "when": "editorTextFocus && !editorReadonly && editorLangId == 'markdown'"
    },
    {
        "key": "f1",
        "command": "git.sync"
    },
    {
        "key": "f1",
        "command": "-workbench.action.showCommands"
    },
]