// Place your key bindings in this file to override the defaultsauto[]
[
    // Toggle between terminal and editor focus
    {
        "key": "[Backquote]",
        "command": "workbench.action.terminal.focus"
    },
    {
        "key": "[Backquote]",
        "command": "workbench.action.focusActiveEditorGroup",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+[Quote]",
        "command": "workbench.action.terminal.openNativeConsole",
        "when": "!terminalFocus"
    },
    {
        "key": "ctrl+shift+c",
        "command": "-workbench.action.terminal.openNativeConsole",
        "when": "!terminalFocus"
    },
    {
        "key": "[Backquote]",
        "command": "latex-workshop.synctex",
        "when": "editorTextFocus && !config.latex-workshop.bind.altKeymap.enabled && editorLangId == 'latex'"
    },
    {
        "key": "ctrl+alt+j",
        "command": "-latex-workshop.synctex",
        "when": "editorTextFocus && !config.latex-workshop.bind.altKeymap.enabled && editorLangId == 'latex'"
    },
    {
        "key": "alt+b",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\textbf{${TM_SELECTED_TEXT}}$0"
        }
    },
    {
        "key": "alt+p",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\pause$0"
        }
    },
    {
        "key": "alt+p",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\pause$0"
        }
    },
    {
        "key": "alt+q",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\quad$0"
        }
    },
    {
        "key": "alt+k",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\medskip$0"
        }
    },
    {
        "key": "alt+x",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\begin{exo}\n\t$0\n\\end{exo}"
        }
    },
    {
        "key": "alt+o",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\boxed{${TM_SELECTED_TEXT}}$0"
        }
    },
    {
        "key": "alt+u",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\underline{${TM_SELECTED_TEXT}}$0"
        }
    },
    {
        "key": "alt+c",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\c{${TM_SELECTED_TEXT}$0}"
        }
    },
    {
        "key": "shift+enter",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\\\\\\\\n"
        }
    },
    {
        "key": "ctrl+enter",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\pause\n\\medskip\n"
        }
    },
    {
        "key": "alt+E",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\begin{alertblock}{Exercice}\n\t$1\n\\end{alertblock}$0"
        }
    },
    {
        "key": "alt+D",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\begin{exampleblock}{Définition}\n\t$1\n\\end{exampleblock}$0"
        }
    },
    {
        "key": "alt+l",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\if\\cor1\\\\\\\\\n\\begin{emphase}\n\t\\textbf{Solution} : ${TM_SELECTED_TEXT}$0\n\\end{emphase}\n\\fi"
        }
    },
    {
        "key": "alt+a",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\begin{algo}{$1}{10cm}\n\t$2\n\\end{algo}$0"
        }
    },
    {
        "key": "ctrl+T",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\begin{block}{Théorème}\n\t$1\n\\end{block}$0"
        }
    },
    {
        "key": "alt+T",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\begin{block}{Théorème}\n\t$1\n\\end{block}$0"
        }
    },
    {
        "key": "alt+e",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == markdown",
        "args": {
            "snippet": "**Exercice** : "
        }
    },
    {
        "key": "alt+t",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus",
        "args": {
            "snippet": "<center><img src=https://github.com/fortierq/tikz/blob/master/$0.png?raw=true width=400></center>"
        }
    },
    {
        "key": "alt+shift+t",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\documentclass[convert={outfile=\\jobname.png}]{standalone}\n\\usepackage{base}\n\n\\begin{document}\n\t$0\n\\end{document}\n"
        }
    },
    {
        "key": "ctrl+i",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\cpp{${TM_SELECTED_TEXT}$1}$0"
        }
    },
    {
        "key": "alt+i",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\ocaml{${TM_SELECTED_TEXT}$1}$0"
        }
    },
    {
        "key": "alt+shift+i",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\python{${TM_SELECTED_TEXT}$1}$0"
        }
    },
    {
        "key": "alt+v",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\vec{${TM_SELECTED_TEXT}$0}"
        }
    },
    {
        "key": "alt+v",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == markdown",
        "args": {
            "snippet": "`${TM_SELECTED_TEXT}`"
        }
    },
    {
        "key": "alt+f",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\begin{frame}[fragile]{\\ttl}\n\t$2\n\\end{frame}\n$0"
        }
    },
    {
        "key": "alt+m",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\begin{center}\r\n    \\begin{minipage}{.7\\textwidth}\r\n    \\begin{minted}[frame=single,framesep=5pt]{ocaml}\r\n$0    \r\n    \\end{minted}\r\n    \\end{minipage}\r\n\\end{center}"
        }
    },
    {
        "key": "alt+shift+m",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\medskip\\begin{emphase}\n\t\\begin{minted}{python}\n$1\n\t\\end{minted}\n\\end{emphase}\n$0"
        }
    },
    {
        "key": "alt+i",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == markdown",
        "args": {
            "snippet": "<center><img src=img/$1 width=300></center>"
        }
    },
    {
        "key": "alt+m",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == markdown",
        "args": {
            "snippet": "<mark>${TM_SELECTED_TEXT}$1</mark>"
        }
    },
    {
        "key": "alt+s",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\section{${TM_SELECTED_TEXT}$0}"
        }
    },
    {
        "key": "alt+shift+s",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == latex",
        "args": {
            "snippet": "\\subsection{${TM_SELECTED_TEXT}$0}"
        }
    },
    {
        "key": "alt+c",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == markdown",
        "args": {
            "snippet": "<center>$1</center>"
        }
    },
    {
        "key": "ctrl+q",
        "command": "-workbench.action.quit"
    },
    {
        "key": "ctrl+b",
        "command": "-markdown.extension.editing.toggleBold",
        "when": "editorTextFocus && !editorReadonly && editorLangId == 'markdown'"
    },
    {
        "key": "f1",
        "command": "git.sync"
    },
    {
        "key": "f1",
        "command": "-workbench.action.showCommands"
    },
    {
        "key": "ctrl+g",
        "command": "workbench.view.scm",
        "when": "workbench.scm.active"
    },
    {
        "key": "ctrl+shift+g",
        "command": "-workbench.view.scm",
        "when": "workbench.scm.active"
    },
    {
        "key": "ctrl+e",
        "command": "workbench.view.explorer",
        "when": "viewContainer.workbench.view.explorer.enabled"
    },
    {
        "key": "ctrl+shift+e",
        "command": "-workbench.view.explorer",
        "when": "viewContainer.workbench.view.explorer.enabled"
    },
    {
        "key": "ctrl+enter",
        "command": "workbench.action.terminal.runSelectedText",
        "when": "editorTextFocus && editorLangId == 'shellscript'"
    },
]